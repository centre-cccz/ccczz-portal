# CCCZ Portal Production Environment Configuration
# Copy this file to .env.production.local and fill in your values

# ==========================================
# DATABASE CONFIGURATION
# ==========================================

# Database URL for production
# Format: postgresql://username:password@host:port/database
DATABASE_URL="postgresql://username:password@localhost:5432/cccz_portal_prod"

# Alternative for MySQL
# DATABASE_URL="mysql://username:password@localhost:3306/cccz_portal_prod"

# ==========================================
# NEXTAUTH CONFIGURATION
# ==========================================

# NextAuth Secret (generate a random string)
NEXTAUTH_SECRET="your-nextauth-secret-here"

# NextAuth URL (your production domain)
NEXTAUTH_URL="https://cccz-portal.com"

# ==========================================
# EMAIL CONFIGURATION (for notifications)
# ==========================================

# SMTP Configuration
SMTP_HOST="smtp.gmail.com"
SMTP_PORT="587"
SMTP_USER="noreply@cccz-portal.com"
SMTP_PASS="your-smtp-password"

# Email settings
FROM_EMAIL="noreply@cccz-portal.com"
FROM_NAME="Centre Culturel Congolais Le Zoo"

# ==========================================
# PAYMENT CONFIGURATION (Stripe)
# ==========================================

# Stripe Keys (for billetterie/payments)
STRIPE_PUBLISHABLE_KEY="pk_live_..."
STRIPE_SECRET_KEY="sk_live_..."
STRIPE_WEBHOOK_SECRET="whsec_..."

# ==========================================
# ANALYTICS & MONITORING
# ==========================================

# Google Analytics
GA_TRACKING_ID="GA_MEASUREMENT_ID"

# Sentry DSN (for error monitoring)
SENTRY_DSN="https://your-sentry-dsn@sentry.io/project-id"

# ==========================================
# CDN & STORAGE
# ==========================================

# Cloudinary (for image storage)
CLOUDINARY_CLOUD_NAME="your-cloud-name"
CLOUDINARY_API_KEY="your-api-key"
CLOUDINARY_API_SECRET="your-api-secret"

# Alternative: AWS S3
AWS_ACCESS_KEY_ID="your-aws-access-key"
AWS_SECRET_ACCESS_KEY="your-aws-secret-key"
AWS_S3_BUCKET="cccz-portal-uploads"
AWS_REGION="eu-west-1"

# ==========================================
# SECURITY
# ==========================================

# API Keys (regenerate for production)
API_SECRET_KEY="your-api-secret-key"

# CORS Origins (comma-separated)
CORS_ORIGINS="https://cccz-portal.com,https://www.cccz-portal.com"

# ==========================================
# PERFORMANCE & CACHING
# ==========================================

# Redis URL (for caching)
REDIS_URL="redis://localhost:6379"

# Cache TTL (in seconds)
CACHE_TTL="3600"

# ==========================================
# EXTERNAL APIs
# ==========================================

# Social Media APIs (optional)
FACEBOOK_APP_ID="your-facebook-app-id"
INSTAGRAM_ACCESS_TOKEN="your-instagram-token"

# Google Maps API (for locations)
GOOGLE_MAPS_API_KEY="your-google-maps-api-key"

# ==========================================
# LOGGING & DEBUGGING
# ==========================================

# Log level (error, warn, info, debug)
LOG_LEVEL="info"

# Enable debug mode (false in production)
DEBUG="false"

# ==========================================
# BACKUP & MAINTENANCE
# ==========================================

# Backup configuration
BACKUP_RETENTION_DAYS="30"
BACKUP_SCHEDULE="0 2 * * *"  # Daily at 2 AM

# Maintenance mode
MAINTENANCE_MODE="false"

# ==========================================
# DEPLOYMENT SPECIFIC
# ==========================================

# Deployment environment
NODE_ENV="production"

# Port (for custom deployments)
PORT="3000"

# Disable Next.js telemetry
NEXT_TELEMETRY_DISABLED="1"

# ==========================================
# CUSTOM CONFIGURATION
# ==========================================

# Site configuration
SITE_NAME="Centre Culturel Congolais Le Zoo"
SITE_DESCRIPTION="Portail officiel du Centre Culturel Congolais Le Zoo"
SITE_URL="https://cccz-portal.com"

# Contact information
CONTACT_EMAIL="contact@cccz-portal.com"
CONTACT_PHONE="+243 XX XXX XXXX"

# Social links
FACEBOOK_URL="https://facebook.com/cccz"
INSTAGRAM_URL="https://instagram.com/cccz"
TWITTER_URL="https://twitter.com/cccz"

# ==========================================
# INSTRUCTIONS
# ==========================================
#
# 1. Copy this file to .env.production.local
# 2. Fill in all required values
# 3. Never commit .env files to version control
# 4. Use strong, unique passwords and keys
# 5. Rotate keys regularly for security
# 6. Test configuration in staging before production
#
# ==========================================