# Database connection for ccclezoo portal
DB_HOST=41.79.235.70
DB_PORT=3306
DB_NAME=ccclezoo_portail
DB_USER=your_db_user
DB_PASS=your_db_password

# Other env vars used by app
NODE_ENV=development
NEXT_PUBLIC_BASE_URL=http://localhost:3000
# ============================================================================
# CCCZ Portal - Environment Variables (SECURE PRODUCTION)
# ============================================================================
# IMPORTANT: Never commit .env.local to version control!
# Generate secure keys: openssl rand -base64 32
# ============================================================================

# ============================================================================
# Application
# ============================================================================
NODE_ENV=production
NEXT_PUBLIC_API_URL=https://api.cccz.cd
NEXT_PUBLIC_BASE_URL=https://www.ccclezoo.cd
NEXT_TELEMETRY_DISABLED=1

# ============================================================================
# Database (MySQL 8.0) - Change these in production!
# ============================================================================
DB_HOST=db
DB_PORT=3306
DB_NAME=ccclezoo_db
DB_USER=ccclezoo_user
DB_PASS=your_secure_database_password_here_change_me
DB_ROOT_PASSWORD=your_secure_root_password_here_change_me
DB_CHARSET=utf8mb4

# ============================================================================
# Cache (Redis 7)
# ============================================================================
REDIS_HOST=cache
REDIS_PORT=6379
REDIS_PASSWORD=your_secure_redis_password_here_change_me

# ============================================================================
# Redis Bull Queue (Event System)
# ============================================================================
BULL_REDIS_URL=redis://:your_secure_redis_password_here_change_me@cache:6379
BULL_PREFIX=cccz:queue

# ============================================================================
# Security Keys - Generate with: openssl rand -base64 32
# ============================================================================
JWT_SECRET=your_jwt_secret_key_here_change_me_in_production
SESSION_SECRET=your_session_secret_key_here_change_me_in_production
NEXTAUTH_SECRET=your_nextauth_secret_here_change_me

# ============================================================================
# Authentication
# ============================================================================
NEXTAUTH_URL=https://cccz.cd

# ============================================================================
# API Keys
# ============================================================================
API_KEY=your_api_key_here_change_me

# ============================================================================
# Email Configuration (Optional)
# ============================================================================
SMTP_HOST=smtp.your-email-provider.com
SMTP_PORT=587
SMTP_USER=your-email@cccz.cd
SMTP_PASS=your_email_password_here
SMTP_FROM=noreply@cccz.cd

# ============================================================================
# Storage Configuration
# ============================================================================
STORAGE_TYPE=local  # local, s3, azure
STORAGE_PATH=/app/public/uploads

# AWS S3 (if STORAGE_TYPE=s3)
# AWS_ACCESS_KEY_ID=your_access_key
# AWS_SECRET_ACCESS_KEY=your_secret_key
# AWS_S3_BUCKET=your_bucket_name
# AWS_S3_REGION=us-east-1

# ============================================================================
# Logging
# ============================================================================
LOG_LEVEL=info
LOG_FORMAT=json

# ============================================================================
# Feature Flags
# ============================================================================
ENABLE_ANALYTICS=true
ENABLE_EMAIL_NOTIFICATIONS=true
ENABLE_SMS_NOTIFICATIONS=false

# ============================================================================
# EVENT SYSTEM CONFIGURATION (NEW)
# ============================================================================

# Event Manager
EVENT_MAX_RETRIES=3
EVENT_NOTIFICATION_DELAY_MS=1000

# Webhook Configuration
WEBHOOK_TIMEOUT=10000
WEBHOOK_MAX_RETRIES=3
WEBHOOK_RETRY_DELAY_MS=5000
WEBHOOK_BATCH_SIZE=10
WEBHOOK_SIGNING_SECRET=your_webhook_signing_secret_change_me

# Job Queue Configuration
JOB_ATTEMPTS=3
JOB_BACKOFF_DELAY=5000
JOBS_SEND_REMINDERS_CRON=0 3 * * *     # 3:00 AM daily
JOBS_ARCHIVE_CRON=0 1 * * *            # 1:00 AM daily
JOBS_REPORT_CRON=0 0 * * 0             # Weekly (Sunday midnight)
JOBS_SEND_REMINDERS_CONCURRENCY=2

# Email Notifications (Event System)
NOTIFICATION_FROM=events@cccz.org
NOTIFICATION_FROM_NAME=Centre Culturel CCCZ
ADMIN_EMAIL=admin@cccz.org
SUPPORT_EMAIL=support@cccz.org
NOTIFY_QUEUE_CONCURRENCY=5

# Microservices Ports
WEBHOOK_SERVICE_PORT=3001
NOTIFICATION_SERVICE_PORT=3002
BULL_BOARD_PORT=3003

# Bull Board Configuration
BULL_BOARD_ENABLED=true
BULL_BOARD_REQUIRE_AUTH=false
BULL_BOARD_USERNAME=admin
BULL_BOARD_PASSWORD=your_bullboard_password

# Audit & Compliance
AUDIT_ENABLED=true
AUDIT_LOG_RETENTION_DAYS=90
GDPR_COMPLIANCE_MODE=true

# Development: Allow localhost webhooks
ALLOW_LOCALHOST_WEBHOOKS=true
