# Next.js
NODE_ENV=development
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# MySQL (cPanel)
DB_HOST=localhost
DB_PORT=3306
DB_USER=your_mysql_user
DB_PASS=your_mysql_password
DB_NAME=ccczz_portal

# Optional full connection string
DATABASE_URL=mysql://your_mysql_user:your_mysql_password@localhost:3306/ccczz_portal

# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# Auth / API
JWT_SECRET=replace_with_a_long_random_secret
API_KEY=replace_with_internal_api_key

# Vercel (for CI/CD only, prefer GitHub Secrets)
VERCEL_TOKEN=vercel_token_here
VERCEL_ORG_ID=vercel_org_id_here
VERCEL_PROJECT_ID=vercel_project_id_here
