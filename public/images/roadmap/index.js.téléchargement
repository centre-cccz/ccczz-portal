function AwaitAnim()
{
	setInterval(function(){
		var current = parseInt($('.js-await-animation').attr('data-current'));
		var next = current + 1;

		if (next > $('.js-await-animation > *').length-1)
		{
			next = 0;
		}
		
		$('.js-await-animation').attr('data-current', next);

		$('.js-await-animation > *').removeClass('active');
		$('.js-await-animation > *').eq(next).addClass('active');
	}, 300);		
}

