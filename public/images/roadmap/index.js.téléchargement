function Switcher()
{
	$('.js-switcher').click(function() 
	{
		if ($(this).hasClass('on'))
		{
			$(this).removeClass('on');
			$(this).addClass('off');
			$(this).find('input').val(0);
		}		
		else if ($(this).hasClass('off'))
		{
			$(this).removeClass('off');
			$(this).addClass('on');
			$(this).find('input').val(1);
		}
	});
}

