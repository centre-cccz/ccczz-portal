function List(wrap, calls, list, values)
{
	var list_dom;
			
	$(calls).click(function() 
	{	
		if ($(calls).hasClass('js-list'))
			list_dom = $(this).find(list);
		else
			list_dom = $(this).parents('.js-list').find(list);
	
		if (!list_dom.is(':visible'))
			list_dom.stop(true, true).fadeIn({ duration: 300, queue: false }).css('display', 'none').slideDown(300);
	});
	
	$(list + ' > *').click(function() 
	{
		$(this).parents(wrap).find(values).text($(this).text());
		
		list_dom.stop(true, true).fadeOut({ duration: 300, queue: false }).slideUp(300);
	});
	
	$(document).click(function(e) {
		if (!$(e.target).hasClass(wrap.replace(".", "")) && $(e.target).parents(wrap).length == 0 && $(e.target).parents(list).length == 0) 
		{
			if (list_dom)
				list_dom.stop(true, true).fadeOut({ duration: 300, queue: false }).slideUp(300);
		}
	});
}

