function DashboardWalletsSlider()
{
	var sliderList = "js-wallets-slide";
	var onDisplay = 1;
	var count = 3;
		
	var currentShift = $('.'+sliderList).attr('data-current');
	$('.'+sliderList).eq(0).css('margin-left', (currentShift * -100) + "%");
	
	$('.'+sliderList).parents('.js-wrap').find('.js-slide-to-left').off('click');
	$('.'+sliderList).parents('.js-wrap').find('.js-slide-to-right').off('click');	
	
	$('.'+sliderList).parents('.js-wrap').find('.js-slide-to-left, .js-slide-to-right').on('click', function() 
	{
		var currentShift = $('.'+sliderList).attr('data-current');
		
		if ($(this).hasClass('js-slide-to-left'))
			currentShift--;
		else
			currentShift++;
		
		if (currentShift >= 0 && currentShift <= count - onDisplay)
		{
			$('.'+sliderList).eq(0).css('margin-left', (currentShift * -100) + "%");			
			$('.'+sliderList).attr('data-current', currentShift);
		}			
	});
}

