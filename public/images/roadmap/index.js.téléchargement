function RangeSlider()
{
	function Update(to_input = true)
	{
		var min = $('#js-main-amount-slider').attr('min');
		var max = $('#js-main-amount-slider').attr('max');
		
		var val = $('#js-selected-amount-input').val();
		
		
		
		var price = $('#js-main-amount-slider').attr('coinprice');
		var AmountUSD = (price / 1.00000000) * val;
		var percent = FactorValue($('#js-main-amount-slider').val(), min, max, 0, 100);
		if(AmountUSD > 25 && AmountUSD < 7500){
			var profitPercent = 7;
		}else if(AmountUSD > 7500 && AmountUSD < 35000){
			var profitPercent = 8;
		}else if(AmountUSD > 35000){
			var profitPercent = 10;
		}else{
			var profitPercent = 7;
		}
		//Формулы профита
		var dailyProfit = val/100*profitPercent;
		var totalProfit = (val/100*profitPercent) * percent;

		//Разные данные
		$('#js-main-amount-slider-min').text(min);
		$('#js-main-amount-slider-max').text(max);
		$('#js-main-percent').css('width', percent+"%");
		$('#js-main-days').text(percent + " Days");

		
		//Профиты
		$('#js-daily-profit').text(dailyProfit.toFixed(8));
		$('#js-total-profit').text(totalProfit.toFixed(8));
	}
	
	Update();
	
	$('#js-main-amount-slider').on('input change', Update);
	$('#js-selected-amount-input').on('input change', Update);
	
	$('#js-selected-amount').on('input change', function() {
		$('#js-main-amount-slider').val($(this).val());
		Update(true);
	});
}

