function ShowScroll(elem, distance)
{
	var elemClone = $(elem).clone(true, true);	
	elemClone.addClass('js-clone');
	elemClone.addClass('fixed');
	elemClone.hide();
	elemClone.css("opacity", "0");
	
	var scroll = $(window).scrollTop();	
	if (scroll > distance)
	{
		if ($(elem+'.js-clone').length == 0)
		{
			$('body').append(elemClone);
			elemClone.show();
			elemClone.css("opacity", "1");
		}
		else
		{
			$(elem+'.js-clone').show();
			$(elem+'.js-clone').css("opacity", "1");
		}
	}		
	else
	{		
		var hidden = $(elem+'.js-clone').css('opacity');
		
		if ($(elem+'.js-clone').length != 0 && hidden != 0)
		{
			$(elem+'.js-clone').css("opacity", "0");
		}
		
		if (hidden == 0)
		{
			$(elem+'.js-clone').remove();
		}
	}

	$(elem).mousemove(function() {
		var hidden = $(elem+'.js-clone').css('opacity');
		
		if (hidden == 0)
			$(elem+'.js-clone').remove();
	});
}


function FactorValue(currentFactor, minFactor, maxFactor, minValue,  maxValue)
{
	if (currentFactor <= minFactor)
		return currentFactor;
	else if (currentFactor >= maxFactor)
		return currentFactor;

	var ratio = (currentFactor - minFactor) / (maxFactor - minFactor);
	return ((maxValue - minValue) * ratio) + minValue;
}

function Support()
{
	Hide();
	
	function Show(target)
	{
		$('.support-wrap').css('opacity', '1');
		$('.js-support-wrap > *').hide();
		$(target).show();
		$('.js-support-wrap').fadeIn(400);
		$('.js-support').css('right', '0');
	}
	
	function Hide()
	{
		var slideRightWidth = $('.js-support').width() + 40;

		$('.js-support').css('right', -slideRightWidth);
		$('.js-support-wrap').fadeOut(400);
		
		$('.js-support-complate').css('opacity', '0');
		$('.js-support-complate').hide();
	}
	
	function ShowComplete()
	{		
		$('.js-support-complate').show();
		$('.js-support-complate').css('opacity', '1');
	}
	
	function Send()
	{
		if ($('.js-input-email').val() == "")
			return;
		
		if ($('.js-input-subject').val() == "")
			return;
		
		if ($('.js-input-text').val() == "")
			return;
		var email = $('.input-on-main').val();
		if(isEmail(email)){
			$.post( "/", { mail: $('.js-input-email').val(), subject: $('.js-input-subject').val(), message: $('.js-input-text').val()} );
			ShowComplete();
		}else{
			return;
		}
	}
	
	$('.js-support-show').click(function() {
		var target = $(this).attr('data-target');
		console.log(target);
		Show(target);
	});
	
	$('.js-support-send').click(function() {
		Send();
	});
	
	$('.js-support-wrap').click(function(e) {
		if (e.target !== this)
			return;
		
		Hide();
	});
	
	$('.js-support-close').click(function() {
		Hide();
	});
}

